      "inputs": [],
      "outputs": [],
      "properties": {
        "text": ""
      },
      "widgets_values": [
        "# Download the models from here: https://huggingface.co/city96/FLUX.1-schnell-gguf/tree/main\n\n# Place the models here: comfyui/models/diffusion_models\n\nThe larger the number after Q, the more VRAM is required, and the higher the image quality generated. For example, Q2 requires less VRAM but generates lower quality images, while Q8 requires more VRAM but generates higher quality images.\n\n\n# Download the clips from here: https://huggingface.co/city96/t5-v1_1-xxl-encoder-gguf/tree/main\n\n# Place in comfyui/models/clip\n\n\n# Required custom node: https://github.com/city96/ComfyUI-GGUF"
      ],
      "color": "#322",
      "bgcolor": "#533"
    },
